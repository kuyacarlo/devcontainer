{
  "image": "kuyacarlo/codespace:latest",
  "customizations": {
    "vscode": {
      "extensions": [
        // Git & GitHub
        "GitHub.vscode-pull-request-github",
        "eamodio.gitlens",

        // Scripting & Tooling
        "mads-hartmann.bash-ide-vscode",
        "timonwong.shellcheck",
        "esbenp.prettier-vscode",
        "mikestead.dotenv",
        "yzhang.markdown-all-in-one",

        // Python & Ruff
        "ms-python.python",
        "ms-python.vscode-pylance",
        "charliermarsh.ruff",
        "ms-python.debugpy",
        "ms-toolsai.jupyter",

        // Go Development
        "golang.go",

        // C/C++ (build-essential)
        "ms-vscode.cpptools",
        "ms-vscode.cmake-tools",

        // Web Frontend & Styling (Next/React, Tailwind, SCSS, Django)
        "bradlc.vscode-tailwindcss",
        "sibiraj-s.vscode-scss-formatter",
        "batisteo.vscode-django",
        "wholroyd.jinja",

        // Databases & SQL
        "mtxr.sqltools",
        "mtxr.sqltools-driver-pg",
        "mtxr.sqltools-driver-sqlite",
        "qwtel.sqlite-viewer",
        "randomfractalsinc.duckdb-sql-tools",

        // Config Formats & API Specs
        "tamasfe.even-better-toml",
        "redhat.vscode-yaml",
        "ms-azuretools.vscode-docker",
        "42crunch.vscode-openapi"
      ],
      "settings": {
        "python.autoComplete.showAdvancedMembers": false,
        "scm.countBadge": "off",
        "terminal.integrated.defaultProfile.linux": "zsh"
      }
    }
  },
  // "postStartCommand": "postStartCommand",
  "remoteUser": "vscode",
  "postCreateCommand": "postCreateCommand",
  "features": {
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {
      "moby": false // avoids trying to install docker-ce, just gives docker CLI
    },
    "ghcr.io/devcontainers-extra/features/act:1": {}
  },
}
